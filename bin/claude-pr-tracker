#!/bin/bash
# claude-pr-tracker — PostToolUse hook that logs PRs created via Claude Code
# Triggered on every Bash tool use; exits fast if not a gh pr create command.

set -euo pipefail

INPUT=$(cat)

# Only process Bash tool calls
TOOL_NAME=$(echo "$INPUT" | jq -r '.tool_name // empty')
[ "$TOOL_NAME" = "Bash" ] || exit 0

# Only process gh pr create commands
COMMAND=$(echo "$INPUT" | jq -r '.tool_input.command // empty')
echo "$COMMAND" | grep -q 'gh pr create' || exit 0

# Extract PR URL from tool output
OUTPUT=$(echo "$INPUT" | jq -r '.tool_output // empty')
PR_URL=$(echo "$OUTPUT" | grep -oE 'https://github\.com/[^[:space:]]*/pull/[0-9]+' | head -1)
[ -n "$PR_URL" ] || exit 0

# Parse repo and PR number from URL
REPO=$(echo "$PR_URL" | sed 's|https://github.com/||; s|/pull/.*||')
PR_NUM=$(echo "$PR_URL" | grep -oE '[0-9]+$')

# Get PR details via gh (title, branch, base)
PR_JSON=$(gh pr view "$PR_NUM" --repo "$REPO" --json title,headRefName,baseRefName 2>/dev/null || echo '{}')
PR_TITLE=$(echo "$PR_JSON" | jq -r '.title // "Unknown"')
BRANCH=$(echo "$PR_JSON" | jq -r '.headRefName // "unknown"')
BASE=$(echo "$PR_JSON" | jq -r '.baseRefName // "unknown"')

DATE=$(date '+%Y-%m-%d')
NOW=$(date '+%Y-%m-%d %H:%M')

# ── Task completion: move matching IN_PROGRESS task to DONE ──
TRACKER_DIR="$HOME/.local/share/agent-monitor/tracker"
IN_PROGRESS="$TRACKER_DIR/IN_PROGRESS.md"
DONE_FILE="$TRACKER_DIR/DONE.md"

if [ -f "$IN_PROGRESS" ]; then
  # Get this agent's session/window from TTY (same pattern as claude-state-hook)
  AGENT_TTY=$(ps -o tty= -p $$ 2>/dev/null | tr -d ' ')
  if [ -n "$AGENT_TTY" ] && [ "$AGENT_TTY" != "??" ]; then
    TMUX_INFO=$(tmux list-panes -a -F '#{pane_tty}|#{pane_id}' 2>/dev/null \
      | grep "^/dev/${AGENT_TTY}|" | head -1)
    AGENT_PANE=$(echo "$TMUX_INFO" | cut -d'|' -f2)

    if [ -n "$AGENT_PANE" ]; then
      # Find task assigned to this agent by pane_id (e.g. %42)
      MATCH_LINE=$(grep -n "^> assigned:.*${AGENT_PANE} " "$IN_PROGRESS" 2>/dev/null | head -1 | cut -d: -f1)

      if [ -n "$MATCH_LINE" ]; then
        # The ## title is the line before the > assigned: metadata
        TASK_START=$((MATCH_LINE - 1))

        # Extract the full task block (## heading to next ## or EOF)
        TASK_BLOCK=$(awk -v s="$TASK_START" '
          NR == s { found=1; print; next }
          found && /^## / { exit }
          found { print }
        ' "$IN_PROGRESS")

        if [ -n "$TASK_BLOCK" ]; then
          # Remove from IN_PROGRESS (atomic write)
          awk -v s="$TASK_START" '
            NR == s { skip=1; next }
            skip && !/^## / { next }
            skip && /^## / { skip=0 }
            { print }
          ' "$IN_PROGRESS" > "${IN_PROGRESS}.tmp" && mv "${IN_PROGRESS}.tmp" "$IN_PROGRESS"

          # Append to DONE with completion metadata
          {
            printf '%s\n' "$TASK_BLOCK"
            printf '> done: %s\n' "$NOW"
            printf '> pr: %s\n' "$PR_URL"
            printf '\n'
          } >> "$DONE_FILE"
        fi
      fi
    fi
  fi
fi

# ── PR log (always runs as supplementary record) ──
LOG_FILE="$HOME/Documents/notes/pr-log.md"

# Create file with header if it doesn't exist
if [ ! -f "$LOG_FILE" ]; then
  printf '# PR Log\n\nTasks completed through Claude Code.\n' > "$LOG_FILE"
fi

# Check if today's date section exists; if not, add it
if ! grep -q "^## $DATE" "$LOG_FILE"; then
  printf '\n## %s\n' "$DATE" >> "$LOG_FILE"
fi

# Append the entry under today's date
printf -- '- [%s#%s](%s) — %s (`%s` -> `%s`)\n' \
  "$REPO" "$PR_NUM" "$PR_URL" "$PR_TITLE" "$BRANCH" "$BASE" >> "$LOG_FILE"
