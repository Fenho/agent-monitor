#!/bin/bash
# Claude Code Agent Dashboard — interactive TUI for monitoring Claude agents
# across tmux sessions. Agent state detected via hooks (claude-state-hook).
# Compatible with macOS bash 3.2. Flicker-free. Vim-navigable.
# Sessions as side-by-side columns, agents stacked vertically within each.

REFRESH_INTERVAL=5
STATE_DIR="/tmp/claude-agent-states"
MAX_COLS=4
MIN_COL_W=30

# Colors & escapes
BOLD='\033[1m'
DIM='\033[2m'
RESET='\033[0m'
GREEN='\033[32m'
YELLOW='\033[33m'
CYAN='\033[36m'
WHITE='\033[37m'
BG_BLUE='\033[44m'
EL='\033[K'
CUR_HOME='\033[H'
ERASE_DOWN='\033[J'

# Pre-expand ANSI codes for safe %s usage in render
X_BG_SEL=$(printf '\033[48;5;237m')
X_RESET=$(printf '\033[0m')
X_BOLD=$(printf '\033[1m')
X_DIM=$(printf '\033[2m')
X_GREEN=$(printf '\033[32m')
X_YELLOW=$(printf '\033[33m')
X_CYAN=$(printf '\033[36m')

SPINNER=("⠋" "⠙" "⠹" "⠸" "⠼" "⠴" "⠦" "⠧" "⠇" "⠏")
SPIN_IDX=0

# Global state
AGENT_COUNT=0
SELECTED=1
FIRST_DRAW=1

# Per-agent raw data (0-indexed)
A_STATE=()
A_WINPANE=()
A_UPTIME=()
C_SESSIONS=()
AGENT_PANE_IDS=()
AGENT_SESSIONS=()
C_THINKING=0
C_WAITING=0
C_IDLE=0

# Session boundaries (populated by fetch_agents)
SESS_NAMES=()    # unique session names
SESS_START=()    # global index of first agent in each session
SESS_COUNT=()    # agent count per session

# State file lookup (bash 3.2 compatible, no associative arrays)
STATE_TTYS=()
STATE_VALS=()

load_agent_states() {
  STATE_TTYS=()
  STATE_VALS=()
  [ -d "$STATE_DIR" ] || return
  for sf in "$STATE_DIR"/*; do
    [ -f "$sf" ] || continue
    local s_state="" s_tty=""
    { read -r s_state; read -r s_tty; } < "$sf"
    if [ -n "$s_tty" ] && [ -n "$s_state" ]; then
      STATE_TTYS+=("$s_tty")
      STATE_VALS+=("$s_state")
    fi
  done
}

get_agent_state() {
  local tty="$1" i=0
  while [ "$i" -lt "${#STATE_TTYS[@]}" ]; do
    if [ "${STATE_TTYS[$i]}" = "$tty" ]; then
      printf '%s' "${STATE_VALS[$i]}"
      return
    fi
    i=$((i + 1))
  done
  printf 'unknown'
}

lookup_tty() {
  local tty="$1" field="$2" line
  for line in "${TMUX_PANE_LINES[@]}"; do
    if [[ "$line" == "${tty}|"* ]]; then
      local rest="${line#*|}"
      case "$field" in
        1) printf '%s' "${rest%%|*}" ;;
        2)
          local after="${rest#*|}"
          local win="${after%%|*}"
          after="${after#*|}"
          printf '%s:%s' "$win" "${after%%|*}"
          ;;
        3)
          local tmp="${rest#*|}"
          tmp="${tmp#*|}"; tmp="${tmp#*|}"
          printf '%s' "${tmp%%|*}"
          ;;
      esac
      return
    fi
  done
}

parse_elapsed() {
  local etime="$1"
  local days=0 hours=0 mins=0 secs=0
  if [[ "$etime" == *-* ]]; then
    days="${etime%%-*}"; etime="${etime#*-}"
  fi
  IFS=: read -ra parts <<< "$etime"
  local n=${#parts[@]}
  if [ "$n" -eq 3 ]; then
    hours="${parts[0]}"; mins="${parts[1]}"; secs="${parts[2]}"
  elif [ "$n" -eq 2 ]; then
    mins="${parts[0]}"; secs="${parts[1]}"
  fi
  days=$((10#$days)); hours=$((10#$hours)); mins=$((10#$mins)); secs=$((10#$secs))
  if [ "$days" -gt 0 ]; then echo "${days}d ${hours}h"
  elif [ "$hours" -gt 0 ]; then echo "${hours}h ${mins}m"
  elif [ "$mins" -gt 0 ]; then echo "${mins}m"
  else echo "${secs}s"; fi
}

fetch_agents() {
  local ps_output
  ps_output=$(ps -eo pid=,tty=,pcpu=,etime=,comm= 2>/dev/null | grep -E 'claude$' | grep -v grep || true)

  AGENT_COUNT=0
  A_STATE=(); A_WINPANE=(); A_UPTIME=()
  C_SESSIONS=(); AGENT_PANE_IDS=(); AGENT_SESSIONS=()
  C_THINKING=0; C_WAITING=0; C_IDLE=0
  SESS_NAMES=(); SESS_START=(); SESS_COUNT=()

  [ -z "$ps_output" ] && return

  local tmux_raw
  tmux_raw=$(tmux list-panes -a -F '#{pane_tty}|#{session_name}|#{window_name}|#{pane_index}|#{pane_id}' 2>/dev/null || true)

  TMUX_PANE_LINES=()
  while IFS= read -r pane_line; do
    TMUX_PANE_LINES+=("${pane_line#/dev/}")
  done <<< "$tmux_raw"

  load_agent_states

  local raw_agents=""
  while read -r pid tty cpu etime _rest; do
    local session winpane pane_id
    session=$(lookup_tty "$tty" 1)
    winpane=$(lookup_tty "$tty" 2)
    pane_id=$(lookup_tty "$tty" 3)
    [ -z "$session" ] && session="unknown"
    [ -z "$winpane" ] && winpane="?"

    if [ -z "$raw_agents" ]; then
      raw_agents="${session}|${winpane}|${pid}|${cpu}|${etime}|${pane_id}|${tty}"
    else
      raw_agents="${raw_agents}
${session}|${winpane}|${pid}|${cpu}|${etime}|${pane_id}|${tty}"
    fi
  done <<< "$ps_output"

  raw_agents=$(printf '%s\n' "$raw_agents" | sort -t'|' -k1,1 -k2,2)

  while IFS='|' read -r session winpane pid cpu etime pane_id tty; do
    AGENT_PANE_IDS+=("$pane_id")
    AGENT_SESSIONS+=("$session")
    C_SESSIONS+=("$session")

    local agent_state
    agent_state=$(get_agent_state "$tty")
    A_STATE+=("$agent_state")
    A_WINPANE+=("$winpane")

    local activity_str
    activity_str=$(parse_elapsed "$etime")
    A_UPTIME+=("$activity_str")

    case "$agent_state" in
      thinking) C_THINKING=$((C_THINKING + 1)) ;;
      waiting)  C_WAITING=$((C_WAITING + 1)) ;;
      *)        C_IDLE=$((C_IDLE + 1)) ;;
    esac

    AGENT_COUNT=$((AGENT_COUNT + 1))
  done <<< "$raw_agents"

  # Build session boundary lookup
  local prev="" i=0
  while [ "$i" -lt "$AGENT_COUNT" ]; do
    local s="${C_SESSIONS[$i]}"
    if [ "$s" != "$prev" ]; then
      SESS_NAMES+=("$s")
      SESS_START+=("$i")
      SESS_COUNT+=(0)
      prev="$s"
    fi
    local si=$(( ${#SESS_COUNT[@]} - 1 ))
    SESS_COUNT[$si]=$(( ${SESS_COUNT[$si]} + 1 ))
    i=$((i + 1))
  done

  if [ "$SELECTED" -gt "$AGENT_COUNT" ]; then SELECTED=$AGENT_COUNT; fi
  if [ "$SELECTED" -lt 1 ] && [ "$AGENT_COUNT" -gt 0 ]; then SELECTED=1; fi
}

# Print one card's status line, padded to $cw visible chars
# Args: agent_idx card_width is_highlighted row_label
print_card_l1() {
  local idx=$1 cw=$2 hl=$3 row_label=$4
  local state="${A_STATE[$idx]}"

  local ic label color
  case "$state" in
    thinking) ic="●"; label="THINKING"; color="$X_GREEN" ;;
    waiting)  ic="◆"; label="WAITING";  color="$X_YELLOW" ;;
    idle)     ic="○"; label="IDLE";     color="$X_DIM" ;;
    *)        ic="?"; label="UNKNOWN";  color="$X_DIM" ;;
  esac

  local vlen=$(( ${#row_label} + 1 + 1 + 1 + ${#label} ))
  local pad=$(( cw - vlen ))
  [ "$pad" -lt 0 ] && pad=0

  local bg_on="" bg_off="" RST="$X_RESET"
  if [ "$hl" -eq 1 ]; then
    bg_on="$X_BG_SEL"; bg_off="$X_RESET"; RST="${X_RESET}${X_BG_SEL}"
  fi

  printf '%s%s %s%s%s %s%s%s%s%*s%s' \
    "$bg_on" "$row_label" \
    "$color" "$ic" "$RST" \
    "$color" "$X_BOLD" "$label" "$RST" \
    "$pad" "" "$bg_off"
}

# Print one card's detail line, padded to $2 visible chars
print_card_l2() {
  local idx=$1 cw=$2 hl=$3
  local wp="${A_WINPANE[$idx]}"
  local up="${A_UPTIME[$idx]}"

  # Truncate winpane if needed to fit card width
  local max_wp=$(( cw - 4 - ${#up} ))
  if [ "$max_wp" -lt 3 ]; then max_wp=3; fi
  if [ "${#wp}" -gt "$max_wp" ]; then
    wp="${wp:0:$max_wp}"
  fi

  local detail="  ${wp}  ${up}"
  local vlen=${#detail}
  local pad=$(( cw - vlen ))
  [ "$pad" -lt 0 ] && pad=0

  local bg_on="" bg_off="" RST="$X_RESET"
  if [ "$hl" -eq 1 ]; then
    bg_on="$X_BG_SEL"; bg_off="$X_RESET"; RST="${X_RESET}${X_BG_SEL}"
  fi

  printf '%s%s%s%s%*s%s' \
    "$bg_on" "$X_DIM" "$detail" "$RST" \
    "$pad" "" "$bg_off"
}

render() {
  if [ "$FIRST_DRAW" -eq 1 ]; then
    clear
    FIRST_DRAW=0
  else
    printf "${CUR_HOME}"
  fi

  local spin="${SPINNER[$SPIN_IDX]}"
  SPIN_IDX=$(( (SPIN_IDX + 1) % ${#SPINNER[@]} ))

  # Terminal width
  local tw
  tw=$(tput cols 2>/dev/null) || tw=80

  printf "${EL}\n"
  printf "  ${BOLD}\033[7m  Agent Dashboard  ${RESET}${EL}\n"
  printf "${EL}\n"

  if [ "$AGENT_COUNT" -eq 0 ]; then
    printf "  ${DIM}No Claude Code agents detected.${RESET}${EL}\n"
    printf "${EL}\n"
    printf "  ${DIM}Start a Claude session in a tmux pane to see it here.${RESET}${EL}\n"
    printf "${EL}\n"
    printf "  ${BOLD}[r]${RESET} Refresh  ${BOLD}[q]${RESET} Quit${EL}\n"
    printf "  ${DIM}${spin} Auto-refresh every ${REFRESH_INTERVAL}s | $(date +%H:%M:%S)${RESET}${EL}\n"
    printf "${ERASE_DOWN}"
    return
  fi

  local total_sessions=${#SESS_NAMES[@]}

  # Render session columns in groups of MAX_COLS
  local group=0
  while [ "$group" -lt "$total_sessions" ]; do
    local group_end=$((group + MAX_COLS))
    [ "$group_end" -gt "$total_sessions" ] && group_end=$total_sessions
    local ncols=$((group_end - group))

    # Column width: divide terminal evenly across session columns
    local cw=$(( (tw - 2) / ncols ))
    while [ "$cw" -lt "$MIN_COL_W" ] && [ "$ncols" -gt 1 ]; do
      ncols=$((ncols - 1))
      cw=$(( (tw - 2) / ncols ))
    done

    # Find max agent count in this group of sessions
    local max_agents=0 c=$group
    while [ "$c" -lt "$group_end" ]; do
      local cnt="${SESS_COUNT[$c]}"
      [ "$cnt" -gt "$max_agents" ] && max_agents=$cnt
      c=$((c + 1))
    done

    # Session header row — numbered
    c=$group
    while [ "$c" -lt "$group_end" ]; do
      local snum=$((c + 1))
      local sname="${SESS_NAMES[$c]}"
      local hdr="┌ ${snum} ${sname}"
      local hdr_len=${#hdr}
      local hdr_pad=$((cw - hdr_len))
      [ "$hdr_pad" -lt 0 ] && hdr_pad=0
      if [ "$c" -eq "$group" ]; then
        printf '  '
      fi
      printf "${BOLD}%s${RESET}%*s" "$hdr" "$hdr_pad" ""
      c=$((c + 1))
    done
    printf "${EL}\n"

    # Render rows of agents — each row is 2 terminal lines (status + detail)
    local row=0
    while [ "$row" -lt "$max_agents" ]; do
      # Line 1: status
      c=$group
      while [ "$c" -lt "$group_end" ]; do
        local s_start="${SESS_START[$c]}"
        local s_count="${SESS_COUNT[$c]}"

        if [ "$c" -eq "$group" ]; then
          printf '  '
        fi

        if [ "$row" -lt "$s_count" ]; then
          local aidx=$((s_start + row))
          local hl=0
          [ "$((aidx + 1))" -eq "$SELECTED" ] && hl=1
          local row_label="[$((c + 1))$((row + 1))]"
          printf '│ '
          print_card_l1 "$aidx" "$((cw - 3))" "$hl" "$row_label"
          printf ' '
        else
          printf '│%*s' "$((cw - 1))" ""
        fi
        c=$((c + 1))
      done
      printf "${EL}\n"

      # Line 2: detail
      c=$group
      while [ "$c" -lt "$group_end" ]; do
        local s_start="${SESS_START[$c]}"
        local s_count="${SESS_COUNT[$c]}"

        if [ "$c" -eq "$group" ]; then
          printf '  '
        fi

        if [ "$row" -lt "$s_count" ]; then
          local aidx=$((s_start + row))
          local hl=0
          [ "$((aidx + 1))" -eq "$SELECTED" ] && hl=1
          printf '│ '
          print_card_l2 "$aidx" "$((cw - 3))" "$hl"
          printf ' '
        else
          printf '│%*s' "$((cw - 1))" ""
        fi
        c=$((c + 1))
      done
      printf "${EL}\n"

      row=$((row + 1))
    done

    # Blank separator between row groups of sessions
    [ "$group_end" -lt "$total_sessions" ] && printf "${EL}\n"

    group=$group_end
  done

  printf "${EL}\n"
  printf "  ${BOLD}Total:${RESET} ${AGENT_COUNT} agents  ${GREEN}${C_THINKING} thinking${RESET}  ${YELLOW}${C_WAITING} waiting${RESET}  ${DIM}${C_IDLE} idle${RESET}${EL}\n"
  printf "${EL}\n"
  printf "  ${BOLD}h/j/k/l${RESET} Nav  ${BOLD}Enter${RESET} Jump  ${BOLD}[S][R]${RESET} Direct  ${BOLD}r${RESET} Refresh  ${BOLD}q${RESET} Quit${EL}\n"
  printf "  ${DIM}${spin} Auto-refresh every ${REFRESH_INTERVAL}s | $(date +%H:%M:%S)${RESET}${EL}\n"
  printf "${ERASE_DOWN}"
}

jump_to_agent() {
  local num="$1"
  [ "$num" -lt 1 ] || [ "$num" -gt "$AGENT_COUNT" ] && return
  local idx=$((num - 1))
  local pane_id="${AGENT_PANE_IDS[$idx]}"
  local session="${AGENT_SESSIONS[$idx]}"
  if [ -n "$pane_id" ] && [ -n "$session" ]; then
    printf 'switch-client -t "%s"\nselect-window -t "%s"\nselect-pane -t "%s"\n' \
      "$session" "$pane_id" "$pane_id" > /tmp/.claude-dashboard-jump
    exit 0
  fi
}

nav_down() {
  [ "$AGENT_COUNT" -eq 0 ] && return
  local idx=$((SELECTED - 1))
  local cur_sess="${C_SESSIONS[$idx]}"
  # Find end of current session
  local sess_end=$idx
  while [ "$sess_end" -lt $((AGENT_COUNT - 1)) ] && [ "${C_SESSIONS[$((sess_end + 1))]}" = "$cur_sess" ]; do
    sess_end=$((sess_end + 1))
  done
  if [ "$idx" -lt "$sess_end" ]; then
    SELECTED=$((idx + 2))
  else
    # Wrap to top of same session
    local sess_start=$idx
    while [ "$sess_start" -gt 0 ] && [ "${C_SESSIONS[$((sess_start - 1))]}" = "$cur_sess" ]; do
      sess_start=$((sess_start - 1))
    done
    SELECTED=$((sess_start + 1))
  fi
}

nav_up() {
  [ "$AGENT_COUNT" -eq 0 ] && return
  local idx=$((SELECTED - 1))
  local cur_sess="${C_SESSIONS[$idx]}"
  # Find start of current session
  local sess_start=$idx
  while [ "$sess_start" -gt 0 ] && [ "${C_SESSIONS[$((sess_start - 1))]}" = "$cur_sess" ]; do
    sess_start=$((sess_start - 1))
  done
  if [ "$idx" -gt "$sess_start" ]; then
    SELECTED=$idx
  else
    # Wrap to bottom of same session
    local sess_end=$idx
    while [ "$sess_end" -lt $((AGENT_COUNT - 1)) ] && [ "${C_SESSIONS[$((sess_end + 1))]}" = "$cur_sess" ]; do
      sess_end=$((sess_end + 1))
    done
    SELECTED=$((sess_end + 1))
  fi
}

nav_left() {
  [ "$AGENT_COUNT" -eq 0 ] && return
  local idx=$((SELECTED - 1))
  local cur_sess="${C_SESSIONS[$idx]}"
  # Find start of current session and current row
  local sess_start=$idx
  while [ "$sess_start" -gt 0 ] && [ "${C_SESSIONS[$((sess_start - 1))]}" = "$cur_sess" ]; do
    sess_start=$((sess_start - 1))
  done
  local row=$((idx - sess_start))
  # Find previous session
  if [ "$sess_start" -eq 0 ]; then
    # Wrap to last session
    local prev_end=$((AGENT_COUNT - 1))
  else
    local prev_end=$((sess_start - 1))
  fi
  local prev_sess="${C_SESSIONS[$prev_end]}"
  local prev_start=$prev_end
  while [ "$prev_start" -gt 0 ] && [ "${C_SESSIONS[$((prev_start - 1))]}" = "$prev_sess" ]; do
    prev_start=$((prev_start - 1))
  done
  local prev_count=$((prev_end - prev_start + 1))
  # Clamp row if target session is shorter
  [ "$row" -ge "$prev_count" ] && row=$((prev_count - 1))
  SELECTED=$((prev_start + row + 1))
}

nav_right() {
  [ "$AGENT_COUNT" -eq 0 ] && return
  local idx=$((SELECTED - 1))
  local cur_sess="${C_SESSIONS[$idx]}"
  # Find start/end of current session and current row
  local sess_start=$idx
  while [ "$sess_start" -gt 0 ] && [ "${C_SESSIONS[$((sess_start - 1))]}" = "$cur_sess" ]; do
    sess_start=$((sess_start - 1))
  done
  local sess_end=$idx
  while [ "$sess_end" -lt $((AGENT_COUNT - 1)) ] && [ "${C_SESSIONS[$((sess_end + 1))]}" = "$cur_sess" ]; do
    sess_end=$((sess_end + 1))
  done
  local row=$((idx - sess_start))
  # Find next session
  if [ "$sess_end" -ge $((AGENT_COUNT - 1)) ]; then
    # Wrap to first session
    local next_start=0
  else
    local next_start=$((sess_end + 1))
  fi
  local next_sess="${C_SESSIONS[$next_start]}"
  local next_end=$next_start
  while [ "$next_end" -lt $((AGENT_COUNT - 1)) ] && [ "${C_SESSIONS[$((next_end + 1))]}" = "$next_sess" ]; do
    next_end=$((next_end + 1))
  done
  local next_count=$((next_end - next_start + 1))
  # Clamp row if target session is shorter
  [ "$row" -ge "$next_count" ] && row=$((next_count - 1))
  SELECTED=$((next_start + row + 1))
}

cleanup() {
  tput cnorm 2>/dev/null || true
}

main() {
  tput civis 2>/dev/null || true
  trap cleanup EXIT
  trap 'FIRST_DRAW=1' WINCH
  trap '' PIPE

  fetch_agents
  render

  local esc_state=0  # 0=normal, 1=got ESC, 2=got ESC+[
  while true; do
    key=""
    if [ "$esc_state" -gt 0 ]; then
      # Integer timeout for bash 3.2 compat; 1s is fine since we already got ESC
      read -rsn1 -t 1 key 2>/dev/null
      local rc=$?
      if [ $rc -ne 0 ] || [ -z "$key" ]; then
        esc_state=0
        render
        continue
      fi
    else
      read -rsn1 -t "$REFRESH_INTERVAL" key 2>/dev/null
      local rc=$?
      if [ $rc -ne 0 ]; then
        fetch_agents; render
        continue
      fi
    fi

    if [ "$esc_state" -eq 0 ]; then
      local key_ord=0
      if [ -n "$key" ]; then
        key_ord=$(printf '%d' "'$key" 2>/dev/null) || key_ord=0
      fi
      if [ "$key_ord" -eq 27 ]; then
        esc_state=1
        continue
      fi
      case "$key" in
        q|Q) exit 0 ;;
        r|R) fetch_agents; render ;;
        j) nav_down; render ;;
        k) nav_up; render ;;
        h) nav_left; render ;;
        l) nav_right; render ;;
        G) [ "$AGENT_COUNT" -gt 0 ] && SELECTED=$AGENT_COUNT; render ;;
        g)
          g2=""
          read -rsn1 -t 1 g2 2>/dev/null || true
          [ "$g2" = "g" ] && [ "$AGENT_COUNT" -gt 0 ] && SELECTED=1
          render
          ;;
        "")
          if [ "$AGENT_COUNT" -gt 0 ]; then
            jump_to_agent "$SELECTED"
          fi
          ;;
        [1-9])
          d2=""
          read -rsn1 -t 1 d2 2>/dev/null || true
          case "$d2" in
            [1-9])
              # key=session number, d2=row number (both 1-indexed)
              local si=$((key - 1))
              local ri=$((d2 - 1))
              if [ "$si" -lt "${#SESS_START[@]}" ] && [ "$ri" -lt "${SESS_COUNT[$si]}" ]; then
                local target=$((SESS_START[si] + ri + 1))
                jump_to_agent "$target"
              fi
              ;;
          esac
          ;;
      esac
    elif [ "$esc_state" -eq 1 ]; then
      if [ "$key" = "[" ]; then
        esc_state=2
        continue
      fi
      esc_state=0
      render
    elif [ "$esc_state" -eq 2 ]; then
      esc_state=0
      case "$key" in
        A) nav_up; render ;;
        B) nav_down; render ;;
        C) nav_right; render ;;
        D) nav_left; render ;;
        *) render ;;
      esac
    fi
  done
}

main
